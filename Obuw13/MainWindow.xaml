<Window x:Class="Obuw13.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:m="clr-namespace:Obuw13.Modeli"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw13"
        mc:Ignorable="d"
         Background="#FFFFFF"
 FontFamily="Arial"
 WindowStartupLocation="CenterScreen"
        Icon="/Icon.png"
        Title="Каталог Товаров" Height="600" Width="900" >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Background="LightGreen">
            <Image Source="/Icon.png"/>
            <Button Click="Vihod" Content="Выход" Width="80" Margin="10,10"/>
            <Button x:Name="BthZakazi" Click="Zakazi" Content="Закази" Width="80" Margin="10,10"/>
            <TextBlock x:Name="txtPolzovatel" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Margin="10" Grid.Row="1" x:Name="PanelPoiska">
            <TextBox x:Name="txtPoisk" Width="200" Margin="5" TextChanged="Poisk"/>
            <ComboBox x:Name="ComboFitr" Width="150" Margin="5" SelectionChanged="Vibor" />
            <ComboBox x:Name="ComboSort" Width="150" Margin="5" SelectionChanged="Vibor" >
                <ComboBoxItem Content="Без сортировки"/>
                <ComboBoxItem Content="По возростанию"/>
                <ComboBoxItem Content="По убыванию"/>
            </ComboBox>
            <Button x:Name="BthDobavit" Click="Dobavit" Width="90" Content="Добавить" Margin="5"/>
            <Button x:Name="BthRedakt" Click="Redakt" Width="90" Content="Изменить" Margin="5"/>
            <Button x:Name="BthUdalit" Click="Udalit" Width="90" Content="Удалить" Margin="5"/>
        </StackPanel>

        <ListView Grid.Row="2" HorizontalContentAlignment="Stretch" Margin="10" x:Name="LvElement" MouseDoubleClick="ClickEl">
            <ListView.ItemTemplate>
                <DataTemplate >
                    <StackPanel Orientation="Horizontal" Margin="10" Background="{Binding CvetFona}">
                        <Image Width="100" Height="100" Source="{Binding PolniyPutKFoto}"/>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Shapka}" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding Opisanie,StringFormat='Описание товара: {0}'}"/>
                            <TextBlock Text="{Binding Proizvoditell.Nazvanie,StringFormat='Производитель: {0}'}"/>
                            <TextBlock Text="{Binding Postavchik.Nazvanie,StringFormat='Поставщик: {0}'}"/>
                            <TextBlock Text="{Binding TecuchayaCena,StringFormat='Цена: {0}'}" TextDecorations="Strikethrough" Foreground="Red" Visibility="{Binding NormalnayaCena}"/>
                            <TextBlock Text="{Binding Cena,StringFormat='{}{0}'}"  Visibility="{Binding NormalnayaCena}"/>
                            <TextBlock Text="{Binding EdinicaIzmereniya.Nazvanie,StringFormat='Единица измерния: {0}'}"/>
                            <TextBlock Text="{Binding Kolichestvo,StringFormat='Количество на складе: {0}'}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Skidka,StringFormat='Действующая скидка: {0}'}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
