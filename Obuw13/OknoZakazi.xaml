<Window x:Class="Obuw13.OknoZakazi"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:m="clr-namespace:Obuw13.Modeli"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Obuw13"
        mc:Ignorable="d"
                Background="#FFFFFF"
FontFamily="Arial"
WindowStartupLocation="CenterScreen"
        Title="Список заказов" Height="450" Width="800" Icon="/Icon.png">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Background="LightGreen">
            <Image Source="/Icon.png"/>
            <Button Click="Nazad" Content="Назад" Width="80" Margin="10,10"/>
            <Button x:Name="BthDobavit" Click="Dobavit" Width="90" Content="Добавить" Margin="5"/>
            <Button x:Name="BthRedakt" Click="Redakt" Width="90" Content="Изменить" Margin="5"/>
            <Button x:Name="BthUdalit" Click="Udalit" Width="90" Content="Удалить" Margin="5"/>
        </StackPanel>

        <ListView Grid.Row="1" HorizontalContentAlignment="Stretch" Margin="10" x:Name="LvElement" MouseDoubleClick="ClickEl">
            <ListView.ItemTemplate>
                <DataTemplate >
                    <StackPanel Orientation="Horizontal" Margin="10" >
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding Id,StringFormat='Артикул заказа: {0}' }" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding StatusZakaza.Nazvanie,StringFormat='Статус заказа: {0}'}"/>
                            <TextBlock Text="{Binding PunktVidachi.Adres,StringFormat='Адрес пункта выдачи: {0}'}"/>
                            <TextBlock Text="{Binding DataZakaza,StringFormat='Дата заказа: {0:dd.MM.yyyy}'}"/>
                           
                        </StackPanel>
                        <TextBlock Text="{Binding DataVidachi,StringFormat='Дата выдачи: {0:dd.MM.yyyy}'}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
